generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id              String                @id @default(cuid())
  cip             String                @unique
  nin             String?               @unique
  name            String
  email           String?
  phone           String?
  password        String
  role            String                @default("CITIZEN")
  registryId      String?               @unique
  registry        CitizenRegistry?      @relation(fields: [registryId], references: [id])
  documents       Document[]
  requests        Request[]
  auditLogs       AuditLog[]
  otpCodes        OtpCode[]
  verifications   VerificationRequest[]
  createdAt       DateTime              @default(now())
}

model OtpCode {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code       String   // 6 chiffres
  channel    String   @default("SMS") // SMS | VOICE
  phoneMask  String   // numéro masqué pour affichage
  consumed   Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([userId, consumed])
}

model CitizenRegistry {
  id               String    @id @default(cuid())
  cip              String    @unique
  firstName        String
  lastName         String
  middleName       String?
  birthDate        DateTime?
  birthPlace       String?
  birthCommune     String?
  birthDepartment  String?
  gender           String
  nationality      String    @default("Béninoise")
  // Source d'origine pour la traçabilité
  sourceType       String    @default("DIGITAL_NATIVE") // DIGITAL_NATIVE, PAPER_DIGITIZED, AGENT_PENDING
  paperReference   String?
  digitizedAt      DateTime?
  digitizedById    String?
  fatherName       String?
  fatherCip        String?
  motherName       String?
  motherCip        String?
  maritalStatus    String    @default("SINGLE")
  spouseName       String?
  spouseCip        String?
  address          String?
  commune          String?
  department       String?
  photoUrl         String?
  biometricHash    String?
  judicialStatus   String    @default("CLEAN")
  judicialDetails  String?
  fiscalStatus     String    @default("UP_TO_DATE")
  cedeaoCardNumber String?
  passportNumber   String?
  enrolledAt       DateTime  @default(now())
  lastUpdatedAt    DateTime  @updatedAt
  user             User?
}

model Document {
  id               String    @id @default(cuid())
  serialNumber     String    @unique
  type             String
  title            String
  fileUrl          String?
  pdfBytes         Bytes?
  qrCode           String    @unique
  payloadHash      String
  signature        String
  signatureAlgo    String    @default("RSA-SHA256")
  keyId            String
  issuingAuthority String
  authorityCode    String
  issuedAt         DateTime  @default(now())
  expiresAt        DateTime?
  validUntil       DateTime?
  revokedAt        DateTime?
  revokeReason     String?
  metadata         String?
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  requestId        String?   @unique
  request          Request?  @relation(fields: [requestId], references: [id])
}

model Request {
  id                  String    @id @default(cuid())
  type                String
  reason              String?
  status              String    @default("PENDING")
  pipelineStep        String?
  exceptionReason     String?
  extractionTarget    String?   // Mairie/Cour à contacter pour numérisation
  extractionAt        DateTime?
  note                String?
  autoProcessed       Boolean   @default(false)
  processingStartedAt DateTime?
  processingEndedAt   DateTime?
  userId              String
  user                User      @relation(fields: [userId], references: [id])
  document            Document?
  payment             Payment?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model Payment {
  id              String    @id @default(cuid())
  requestId       String    @unique
  request         Request   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  userId          String
  amount          Int       // FCFA, integer cents
  currency        String    @default("XOF")
  method          String    // MTN_MOMO, MOOV_MONEY, CELTIIS_CASH, CARD
  status          String    @default("PENDING")  // PENDING, COMPLETED, FAILED, REFUNDED
  transactionRef  String?   @unique
  phoneNumber     String?
  paidAt          DateTime?
  refundedAt      DateTime?
  failureReason   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String?
  actor        User?    @relation(fields: [actorId], references: [id])
  actorType    String
  action       String
  resourceType String?
  resourceId   String?
  ip           String?
  userAgent    String?
  metadata     String?
  prevHash     String?
  hash         String
  createdAt    DateTime @default(now())

  @@index([resourceType, resourceId])
  @@index([createdAt])
}

model VerifierApp {
  id            String                @id @default(cuid())
  apiKey        String                @unique
  name          String                // ex: "BNP Paribas Bénin"
  category      String                // BANK, EMPLOYER, EMBASSY, TELECOM, OTHER
  contactEmail  String?
  isActive      Boolean               @default(true)
  createdAt     DateTime              @default(now())
  requests      VerificationRequest[]
}

model VerificationRequest {
  id                String       @id @default(cuid())
  verifierId        String
  verifier          VerifierApp  @relation(fields: [verifierId], references: [id])
  citizenCip        String       // CIP du citoyen cible
  citizenId         String?
  citizen           User?        @relation(fields: [citizenId], references: [id])
  attributesAsked   String       // JSON string array
  purpose           String?      // pourquoi la banque demande
  status            String       @default("PENDING")
                                 // PENDING -> AUTHORIZED / DENIED / EXPIRED
  responseAttrs     String?      // JSON object des valeurs si autorisé
  responseSignature String?      // signature de la réponse
  responseKeyId     String?
  responseHash      String?
  authorizedAt      DateTime?
  deniedAt          DateTime?
  expiresAt         DateTime
  createdAt         DateTime     @default(now())

  @@index([citizenCip, status])
}

model SigningKey {
  id            String    @id @default(cuid())
  keyId         String    @unique
  algorithm     String    @default("RSA-2048")
  publicKey     String
  privateKeyEnc String
  authority     String
  authorityCode String    @unique
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  rotatedAt     DateTime?
}
